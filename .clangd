CompileFlags:
  # Use the compile_commands.json generated by CMake in the build directory.
  CompilationDatabase: build
  # Inject warning flags that CMake doesn't pass, so the IDE surfaces them.
  Add:
    - -Wall
    - -Wextra
    - -Wunused-variable
    - -Wunused-parameter
    - -Wunused-but-set-variable
  # Strip flags that clangd doesn't understand (e.g. GCC-specific ones).
  Remove:
    - -fno-canonical-system-headers
    - -Wno-error=maybe-uninitialized

Diagnostics:
  # Surface clang-tidy checks useful for a modern C++20 codebase.
  ClangTidy:
    Add:
      - bugprone-*
      - clang-analyzer-*
      - modernize-use-nullptr
      - modernize-use-override
      - modernize-use-default-member-init
      - modernize-loop-convert
      - performance-unnecessary-copy-initialization
      - performance-unnecessary-value-param
      - readability-redundant-smartptr-get
    Remove:
      - bugprone-easily-swappable-parameters
  # Suppress diagnostics generated from third-party / system headers.
  Suppress:
    - pp_including_mainfile_in_preamble
  UnusedIncludes: Strict

Completion:
  # Show all overloads, not just the first one.
  AllScopes: true

Hover:
  ShowAKA: true

Index:
  Background: Build

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true
  Designators: true
